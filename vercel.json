{
  "buildCommand": "npm run build",
  "framework": "nextjs",
  "rewrites": [
    {
      "source": "/:selliver((?!api|admin|portal|_next)[^/]+)/:data(\\d{4}-\\d{2}-\\d{2})/:module+",
      "destination": "/api/serve-course?selliver=:selliver&data=:data&module=:module"
    }
  ],
  "headers": [
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=300, must-revalidate" }
      ]
    }
  ],
  "functions": {
    "pages/api/generate-course.ts": {
      "maxDuration": 300
    }
  }
}
