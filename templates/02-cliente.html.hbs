<!DOCTYPE html>
<html lang="pt-BR">
<head>
{{> head}}
</head>
<body class="min-h-screen">

{{> header}}

<main class="max-w-2xl mx-auto px-4 py-8">

  <div class="mb-10">
    <p class="text-purple-600 font-bold text-sm tracking-wider mb-2">PILAR 2 · CLIENTE</p>
    <h1 class="text-4xl font-bold leading-tight mb-3">{{module.title}}</h1>
    <p class="text-lg text-gray-700 mb-4">Você não vende pra "mulheres 25-45". Você vende pra Carla. Conheça ela antes de abrir a live.</p>
    <div class="flex flex-wrap gap-4 text-sm text-gray-600">
      <span>⏱️ 20 minutos</span>
      <span>🎯 Refrasear 5 frases marketeiras em ≤15s cada</span>
      <span>📝 Quiz P2 (4 perguntas)</span>
    </div>
  </div>

  <!-- Persona Narrada -->
  <section class="mb-8">
    <h2 class="text-xl font-bold mb-3">👤 2.1 · Persona Narrada</h2>
    <p class="text-xs text-gray-500 mb-3">NUNCA demografia. SEMPRE história específica.</p>
    <div class="bg-gradient-to-br from-purple-900 to-black text-white rounded-2xl p-6">
      <div class="flex items-center gap-4 mb-4">
        <div class="w-12 h-12 bg-purple-500 rounded-full flex items-center justify-center text-2xl font-black">
          {{pilar_2_cliente.persona_narrada.nome}}
        </div>
        <div>
          <p class="font-bold text-white text-lg">{{pilar_2_cliente.persona_narrada.nome}}, {{pilar_2_cliente.persona_narrada.idade}} anos</p>
          <p class="text-purple-300 text-sm">{{pilar_2_cliente.persona_narrada.profissao}} · {{pilar_2_cliente.persona_narrada.cidade}}</p>
        </div>
      </div>
      <div class="bg-white bg-opacity-10 rounded-xl p-4">
        <p class="text-xs text-purple-300 font-bold tracking-wider mb-2">DOR COM CENA (1ª PESSOA)</p>
        <p class="text-gray-100 italic text-sm leading-relaxed">"{{pilar_2_cliente.persona_narrada.cena_especifica}}"</p>
      </div>
    </div>
  </section>

  <!-- 5 Whys -->
  <section class="mb-8">
    <h2 class="text-xl font-bold mb-3">🔍 2.2 · 5 Whys (dor real por baixo da dor declarada)</h2>
    <div class="space-y-2">
      {{#each pilar_2_cliente.5_whys}}
      <div class="flex items-start gap-3 bg-white border border-gray-100 rounded-lg px-4 py-3">
        <span class="text-purple-600 font-black w-6 flex-shrink-0">{{@index}}</span>
        <span class="text-gray-700 text-sm">{{.}}</span>
        {{#if @last}}<span class="text-xs text-red-500 font-bold ml-auto whitespace-nowrap">← dor primária</span>{{/if}}
      </div>
      {{/each}}
    </div>
  </section>

  <!-- LF8 + Status + JTBD -->
  <section class="mb-8">
    <h2 class="text-xl font-bold mb-3">🧠 2.3 · Motivação de compra (LF8 + Status + JTBD)</h2>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <div class="bg-purple-50 border border-purple-100 rounded-xl p-4">
        <p class="text-xs font-bold text-purple-600 tracking-wider mb-2">LF8 DOMINANTE</p>
        <ul class="space-y-1">
          {{#each pilar_2_cliente.lf8_dominante}}
          <li class="text-sm text-gray-700">• {{.}}</li>
          {{/each}}
        </ul>
      </div>
      <div class="bg-blue-50 border border-blue-100 rounded-xl p-4">
        <p class="text-xs font-bold text-blue-600 tracking-wider mb-2">STATUS TYPE</p>
        <p class="text-sm font-bold text-gray-800 uppercase">{{pilar_2_cliente.status_type}}</p>
      </div>
      <div class="bg-green-50 border border-green-100 rounded-xl p-4">
        <p class="text-xs font-bold text-green-600 tracking-wider mb-2">JTBD</p>
        <p class="text-sm text-gray-700 italic">{{pilar_2_cliente.jtbd}}</p>
      </div>
    </div>
  </section>

  <!-- Awareness + Sophistication -->
  <section class="mb-8">
    <h2 class="text-xl font-bold mb-3">📊 2.4 · Awareness + Sophistication (Schwartz)</h2>
    <div class="grid grid-cols-2 gap-4 mb-4">
      <div class="bg-gray-50 border border-gray-200 rounded-xl p-4">
        <p class="text-xs font-bold text-gray-500 tracking-wider mb-1">AWARENESS LEVEL</p>
        <p class="text-lg font-black text-purple-700">{{pilar_2_cliente.awareness_level}}</p>
      </div>
      <div class="bg-gray-50 border border-gray-200 rounded-xl p-4">
        <p class="text-xs font-bold text-gray-500 tracking-wider mb-1">SOPHISTICATION LEVEL</p>
        <p class="text-lg font-black text-purple-700">{{pilar_2_cliente.sophistication_level}} / 5</p>
      </div>
    </div>
    <div class="bg-purple-50 border border-purple-200 rounded-xl p-4">
      <p class="text-xs font-bold text-purple-600 tracking-wider mb-2">ESTRATÉGIA DE HOOK BASEADA NO NÍVEL</p>
      <p class="text-sm text-gray-700">{{pilar_2_cliente.awareness_sophistication_strategy}}</p>
    </div>
  </section>

  <!-- Belief Charts -->
  <section class="mb-8">
    <h2 class="text-xl font-bold mb-3">💡 2.5 · Belief Charts (Garfinkel)</h2>
    <p class="text-xs text-gray-500 mb-3">Vai além de objeção declarada — são crenças implícitas que bloqueiam a venda.</p>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div class="bg-green-50 border border-green-200 rounded-xl p-4">
        <p class="text-xs font-bold text-green-600 tracking-wider mb-3">✅ INSTALAR (reforçar)</p>
        <ul class="space-y-2">
          {{#each pilar_2_cliente.belief_charts.instalar}}
          <li class="text-sm text-gray-700 flex items-start gap-2"><span class="text-green-500 flex-shrink-0">+</span>{{.}}</li>
          {{/each}}
        </ul>
      </div>
      <div class="bg-red-50 border border-red-200 rounded-xl p-4">
        <p class="text-xs font-bold text-red-600 tracking-wider mb-3">❌ DERRUBAR (substituir)</p>
        <ul class="space-y-2">
          {{#each pilar_2_cliente.belief_charts.derrubar}}
          <li class="text-sm text-gray-700 flex items-start gap-2"><span class="text-red-500 flex-shrink-0">−</span>{{.}}</li>
          {{/each}}
        </ul>
      </div>
    </div>
  </section>

  <!-- Drill P2 -->
  <div class="bg-black text-white rounded-xl p-6 mb-6">
    <h3 class="font-bold text-lg mb-2">🎯 Drill P2 · Refrasear frases marketeiras</h3>
    <p class="text-gray-300 text-sm mb-3">{{outputs_mensuraveis.drill_p2}}</p>
    <p class="text-xs text-purple-400">Aprovação: zero jargão · 1ª pessoa · cena específica · ≤15s por frase.</p>
  </div>

  <!-- Quiz P2 -->
  <section class="mb-8">
    <h2 class="text-xl font-bold mb-4">📝 Quiz P2 · 4 perguntas</h2>
    <div class="space-y-4">
      {{#each outputs_mensuraveis.quiz_p2}}
      <div class="bg-white border border-gray-100 rounded-xl p-4">
        <p class="font-semibold text-gray-900 mb-3">{{@index}}. {{pergunta}}</p>
        <div class="space-y-2">
          {{#each opcoes}}
          <label class="flex items-center gap-3 cursor-pointer text-sm text-gray-700">
            <input type="radio" name="q2_{{../@index}}" value="{{.}}" class="w-4 h-4 text-purple-600">
            <span>{{.}}</span>
          </label>
          {{/each}}
        </div>
        <details class="mt-3">
          <summary class="text-xs text-purple-500 cursor-pointer font-semibold">Ver resposta</summary>
          <p class="text-sm text-green-700 mt-2 font-bold">✅ {{resposta}}</p>
        </details>
      </div>
      {{/each}}
    </div>
  </section>

  <!-- Nav -->
  <div class="flex justify-between mt-8 pt-8 border-t border-gray-100">
    <a href="01-produto.html" class="text-sm text-gray-600 hover:text-purple-600">← Pilar 1 · Produto</a>
    <a href="03-concorrencia.html" class="bg-purple-600 text-white px-6 py-3 rounded-xl font-bold text-sm hover:bg-purple-700">Pilar 3 · Concorrência →</a>
  </div>

</main>
</body>
</html>
